# ===========================================
# SFC AI 財報分析系統 - 環境變量配置
# ===========================================
# 複製此文件為 .env 並根據實際情況修改
# ===========================================

# ===========================================
# LLM Backend 配置 (CPU/GPU 分流)
# ===========================================

# CPU 用家：使用 API (推薦，不消耗本地資源)
# GPU 用家：使用 Local/Ollama (充分利用 GPU)

# 選項 1: API 模式 (CPU 用家 / 唔想用 GPU)
LLM_BACKEND=api
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_API_BASE=https://coding.dashscope.aliyuncs.com/v1

# 選項 2: Local 模式 (GPU 用家 - vLLM)
# 取消註釋以下配置，並使用 GPU docker-compose：
# LLM_BACKEND=local
# VLLM_PORT=5000
# VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# TORCH_DEVICE=cuda

# 選項 3: Ollama 模式 (輕量級本地部署)
# 需要先在本機運行 ollama serve
# LLM_BACKEND=ollama
# OLLAMA_HOST=host.docker.internal:11434
# OLLAMA_MODEL=qwen2.5-vl:7b

# ===========================================
# 嵌入模型配置 (用於 Hybrid Search)
# ===========================================

# OpenAI API Key (推薦使用)
OPENAI_API_KEY=sk-your-openai-api-key-here

# 嵌入 API 配置 (可選，如不設置則默認使用 OpenAI)
# EMBEDDING_API_KEY=your-api-key
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-large

# ===========================================
# PDF 解析配置 (LlamaParse - v3.0 简化架构)
# ===========================================

# 🌟 Llama Cloud API Key（替代 OpenDataLoader/Docling）
# 获取 API Key: https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=llx-your-llama-cloud-api-key-here

# 解析层级：
# - agentic: 高精度 Agentic OCR（推荐）
# - cost_effective: 平衡模式
# - fast: 快速模式
LLAMAPARSE_TIER=agentic

# ===========================================
# 數據庫配置
# ===========================================

# PostgreSQL
POSTGRES_HOST=postgres-financial
POSTGRES_PORT=5432
POSTGRES_DB=annual_reports
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_change_me

# 數據庫連接字符串 (供 Python 使用)
DATABASE_URL=postgresql://postgres:postgres_password_change_me@postgres-financial:5432/annual_reports

# ===========================================
# Data 存儲配置
# ===========================================

# Raw Data 存儲路徑 (Docker Volume)
DATA_DIR=/app/data/raw

# 批量處理配置
BATCH_SIZE=10
MAX_CONCURRENT_TASKS=5

# ===========================================
# 圖譜數據庫配置 (Apache AGE)
# ===========================================
# 🌟 商業友好的圖數據庫解決方案
# Apache AGE 是 PostgreSQL 擴展，無需額外數據庫
# License: Apache License 2.0 + PostgreSQL License
# 完全商用友好，無 GPL 傳染風險

# 啟用 Apache AGE（在 PostgreSQL 中執行）
# CREATE EXTENSION IF NOT EXISTS age;
# SELECT create_graph('financial_graph');

# 圖譜名稱
AGE_GRAPH_NAME=financial_graph

# ===========================================
# Nanobot 配置
# ===========================================

LOG_LEVEL=INFO
NANOBOT_CONFIG=/app/config/config.json

# ===========================================
# Docker 部署配置
# ===========================================

# GPU 用家請使用：docker-compose -f docker-compose.yml -f docker-compose.gpu.yml up
# CPU 用家請使用：docker-compose up

# GPU 配置 (僅 gpu.yml 使用)
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
