# ===========================================
# SFC AI 財報分析系統 - 環境變量配置
# ===========================================
# 複製此文件為 .env 並根據實際情況修改

# ===========================================
# 嵌入模型配置 (用於 MongoDB 語義搜索)
# ===========================================

# OpenAI API Key (推薦使用)
OPENAI_API_KEY=sk-your-openai-api-key-here

# 嵌入 API 配置 (可選，如不設置則默認使用 OpenAI)
# EMBEDDING_API_KEY=your-api-key
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-large

# ===========================================
# 數據庫配置
# ===========================================

# PostgreSQL
POSTGRES_HOST=postgres-financial
POSTGRES_PORT=5432
POSTGRES_DB=annual_reports
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_change_me

# MongoDB
MONGODB_HOST=mongodb-docs
MONGODB_PORT=27017
MONGODB_DB=annual_reports
MONGODB_USER=mongo
MONGODB_PASSWORD=mongo_password_change_me

# ===========================================
# Vanna AI 配置
# ===========================================

# Vanna API Key (可選，如不設置則使用本地 ChromaDB)
# VANNA_API_KEY=your-vanna-api-key
VANNA_MODEL=financial-sql

# ChromaDB 持久化路徑 (Docker 容器內)
VANNA_PERSIST_DIR=/app/data/vanna_db

# ===========================================
# Nanobot 配置
# ===========================================

LOG_LEVEL=INFO
NANOBOT_CONFIG=/app/config/config.json

# ===========================================
# OpenDataLoader 配置 (可選)
# ===========================================

# 如需要使用 GPU 加速表格解析
# USE_CUDA=true
