{
  "description": "DDL Whitelist for Vanna - Allowed Tables and Columns",
  "version": "2.1.0",
  "allowed_tables": [
    {
      "name": "v_companies_for_vanna",
      "allowed_columns": ["id", "name_en", "name_zh", "stock_code", "sector", "is_industry_confirmed", "primary_industry", "created_at"],
      "note": "⭐ CRITICAL: 永遠使用這個視圖來查詢公司的行業，它已經自動解決了行業雙軌制 (Index vs AI)。"
    },
    {
      "name": "v_documents_for_vanna",
      "allowed_columns": ["id", "doc_id", "filename", "report_type", "year", "processing_status", "uploaded_at", "owner_company_name_en", "owner_company_name_zh", "owner_stock_code", "doc_theme", "doc_region"],
      "note": "⭐ CRITICAL: 永遠使用這個視圖來查詢文檔，它已經攤平了 JSONB 並關聯了母公司。"
    },
    {
      "name": "documents",
      "allowed_columns": ["id", "doc_id", "filename", "report_type", "owner_company_id", "year", "processing_status", "dynamic_attributes", "uploaded_at", "created_at"],
      "note": "文檔主表。report_type 区分 'annual_report' 或 'index_report'。owner_company_id 对于 Index Report 可为 NULL。"
    },
    {
      "name": "document_companies",
      "allowed_columns": ["id", "document_id", "company_id", "relation_type", "extracted_industries", "extraction_source", "created_at"],
      "note": "純橋樑表，用 relation_type 區分提及類型 (如 index_constituent, subsidiary, competitor)。"
    },
    {
      "name": "document_processing_history",
      "allowed_columns": ["id", "document_id", "stage", "status", "details", "error_message", "created_at"],
      "note": "Tracks document processing stages"
    },
    {
      "name": "review_queue",
      "allowed_columns": ["id", "document_id", "company_id", "review_type", "priority", "status", "issue_description", "ai_suggestion", "human_decision", "reviewer_id", "reviewed_at", "created_at"],
      "note": "Human review queue for uncertain AI decisions"
    },
    {
      "name": "vanna_training_data",
      "allowed_columns": ["id", "question", "sql_query", "table_name", "documentation", "quality_score", "is_verified", "created_at"],
      "note": "Vanna training data storage"
    },
    {
      "name": "companies",
      "allowed_columns": ["id", "stock_code", "name_en", "name_zh", "sector", "auditor", "auditor_opinion", "ultimate_controlling_shareholder", "principal_banker", "extra_data", "listing_status", "listing_date", "created_at"],
      "note": "公司主表。对于行业查询，请使用 v_companies_for_vanna 而不是直接查询此表。"
    },
    {
      "name": "v_companies_resolved",
      "allowed_columns": ["id", "stock_code", "display_name_en", "display_name_zh", "industry", "sector", "auditor", "auditor_opinion", "ultimate_controlling_shareholder", "principal_banker", "listing_status", "listing_date"],
      "note": "Recommended view for company name queries - automatically selects best name (index > extracted)"
    },
    {
      "name": "financial_metrics",
      "allowed_columns": ["id", "company_id", "year", "fiscal_period", "metric_name", "metric_name_zh", "original_metric_name", "value", "unit", "standardized_value", "standardized_currency", "category", "source_file", "source_page"],
      "critical_note": "For cross-company comparisons (ranking, top N), ALWAYS use standardized_value. NEVER compare raw value directly as units differ across companies."
    },
    {
      "name": "market_data",
      "allowed_columns": ["id", "company_id", "trade_date", "closing_price", "opening_price", "high_price", "low_price", "issued_shares", "trading_volume", "source"]
    },
    {
      "name": "key_personnel",
      "allowed_columns": ["id", "company_id", "year", "person_name", "person_name_zh", "role", "role_zh", "committee", "committee_position", "biography", "biography_zh", "age", "source_file", "source_page"]
    },
    {
      "name": "shareholdings",
      "allowed_columns": ["id", "company_id", "year", "shareholder_name", "shareholder_name_zh", "shareholder_type", "percentage_held", "shares_held", "trust_name", "trustee_name", "source_file", "source_page"]
    },
    {
      "name": "specific_events",
      "allowed_columns": ["id", "company_id", "event_category", "event_title", "event_detail", "event_date", "effective_date", "announcement_date", "metric_value", "metric_unit", "source_file", "source_page"]
    },
    {
      "name": "revenue_breakdown",
      "allowed_columns": ["id", "company_id", "year", "category", "category_type", "percentage", "amount", "currency", "sub_category", "sub_percentage", "source_file", "source_page"]
    },
    {
      "name": "debt_maturity",
      "allowed_columns": ["id", "company_id", "year", "maturity_year", "amount", "currency", "debt_type", "source_file", "source_page"]
    },
    {
      "name": "listing_applications",
      "allowed_columns": ["id", "company_id", "year", "application_count", "approved_count", "rejected_count", "source_file", "source_page"]
    },
    {
      "name": "document_pages",
      "allowed_columns": ["id", "company_id", "doc_id", "year", "page_num", "markdown_content", "content_type", "has_images", "has_charts", "source_file"]
    },
    {
      "name": "raw_artifacts",
      "allowed_columns": ["id", "artifact_id", "doc_id", "company_id", "artifact_type", "content", "source_file", "source_page"]
    }
  ],
  "forbidden_keywords": ["DROP", "TRUNCATE", "DELETE FROM companies", "DELETE FROM financial_metrics", "UPDATE companies SET", "INSERT INTO companies", "ALTER TABLE"],
  "max_result_rows": 1000
}