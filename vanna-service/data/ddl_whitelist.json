{
  "description": "DDL Whitelist for Vanna - Allowed Tables and Columns",
  "version": "2.0.0",
  "allowed_tables": [
    {
      "name": "documents",
      "allowed_columns": ["id", "filename", "report_type", "is_index_report", "parent_company", "index_theme", "confirmed_industry", "ai_extracted_industries", "dynamic_attributes", "created_at", "updated_at"],
      "note": "Main document table for Agentic Dynamic Ingestion. Supports JSONB dynamic_attributes and Rule A/B industry assignment."
    },
    {
      "name": "document_companies",
      "allowed_columns": ["id", "document_id", "company_name", "stock_code", "assigned_industry", "ai_suggested_industries", "industry_source", "created_at"],
      "note": "Companies linked to documents. industry_source = 'confirmed' (Rule A) or 'ai_extracted' (Rule B)."
    },
    {
      "name": "document_processing_history",
      "allowed_columns": ["id", "document_id", "stage", "status", "metadata", "created_at"],
      "note": "Tracks document processing stages (agent_ingestion, opendataloader, etc.)"
    },
    {
      "name": "document_chunks",
      "allowed_columns": ["id", "document_id", "chunk_index", "content", "embedding", "created_at"],
      "note": "Text chunks extracted from documents for RAG search"
    },
    {
      "name": "document_tables",
      "allowed_columns": ["id", "document_id", "table_index", "table_data", "bounding_box", "created_at"],
      "note": "Tables extracted from documents"
    },
    {
      "name": "review_queue",
      "allowed_columns": ["id", "document_id", "review_type", "ai_suggestion", "confidence", "reason", "context", "status", "reviewed_by", "reviewed_at", "final_decision", "created_at"],
      "note": "Human review queue for uncertain AI decisions"
    },
    {
      "name": "vanna_training_data",
      "allowed_columns": ["id", "training_type", "content", "created_at"],
      "note": "Vanna training data storage"
    },
    {
      "name": "companies",
      "allowed_columns": ["id", "stock_code", "name_en_index", "name_en_extracted", "name_zh_extracted", "name_en", "name_zh", "industry", "sector", "auditor", "auditor_opinion", "ultimate_controlling_shareholder", "principal_banker", "listing_status", "listing_date"]
    },
    {
      "name": "v_companies_resolved",
      "allowed_columns": ["id", "stock_code", "display_name_en", "display_name_zh", "industry", "sector", "auditor", "auditor_opinion", "ultimate_controlling_shareholder", "principal_banker", "listing_status", "listing_date"],
      "note": "Recommended view for Vanna queries - automatically selects best company name (index > extracted)"
    },
    {
      "name": "financial_metrics",
      "allowed_columns": ["id", "company_id", "year", "fiscal_period", "metric_name", "metric_name_zh", "original_metric_name", "value", "unit", "standardized_value", "standardized_currency", "category", "source_file", "source_page"],
      "critical_note": "For cross-company comparisons (ranking, top N), ALWAYS use standardized_value. NEVER compare raw value directly as units differ across companies."
    },
    {
      "name": "market_data",
      "allowed_columns": ["id", "company_id", "trade_date", "closing_price", "opening_price", "high_price", "low_price", "issued_shares", "trading_volume", "market_cap"]
    },
    {
      "name": "key_personnel",
      "allowed_columns": ["id", "company_id", "year", "person_name", "person_name_zh", "role", "role_zh", "committee", "committee_position", "biography", "biography_zh", "age", "source_file", "source_page"]
    },
    {
      "name": "shareholdings",
      "allowed_columns": ["id", "company_id", "year", "shareholder_name", "shareholder_name_zh", "shareholder_type", "percentage_held", "shares_held", "trust_name", "trustee_name", "source_file", "source_page"]
    },
    {
      "name": "specific_events",
      "allowed_columns": ["id", "company_id", "doc_id", "event_category", "event_type", "event_title", "event_detail", "event_date", "effective_date", "metric_value", "metric_unit", "source_file", "source_page"]
    },
    {
      "name": "revenue_breakdown",
      "allowed_columns": ["id", "company_id", "year", "category", "category_type", "percentage", "amount", "currency", "sub_category", "sub_percentage", "source_file", "source_page"]
    },
    {
      "name": "debt_maturity",
      "allowed_columns": ["id", "company_id", "year", "maturity_year", "maturity_date", "amount", "currency", "debt_type", "source_file", "source_page"]
    },
    {
      "name": "listing_applications",
      "allowed_columns": ["id", "company_id", "doc_id", "year", "application_count", "approved_count", "rejected_count", "source_file", "source_page"]
    },
    {
      "name": "document_pages",
      "allowed_columns": ["id", "company_id", "doc_id", "year", "page_num", "markdown_content", "content_type", "has_images", "has_charts", "source_file"]
    }
  ],
  "forbidden_keywords": ["DROP", "TRUNCATE", "DELETE FROM companies", "DELETE FROM financial_metrics", "UPDATE companies SET", "INSERT INTO companies"],
  "max_result_rows": 1000
}