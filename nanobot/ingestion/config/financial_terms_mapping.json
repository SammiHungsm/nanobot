{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "港股财务名词标准化对照表 (Master Data Taxonomy) - 与数据库 Schema v2.3 对齐",
  "version": "3.1.0",
  
  "instruction": "【强制规则】提取数据时，请优先将财报上的名词映射到 'core_metrics' 的 standard_name。若为未定义的指标或特定公司的业务/地区分类，请套用 fallback_rule 动态生成。",
  
  "database_schema_reference": {
    "table": "financial_metrics",
    "key_fields": {
      "metric_name": "VARCHAR(100) NOT NULL - 标准英文名 (Taxonomy)",
      "metric_name_zh": "VARCHAR(100) - 标准中文名",
      "original_metric_name": "VARCHAR(200) - 原始名称 (Traceability)",
      "value": "NUMERIC(20, 2) - 原始值",
      "unit": "VARCHAR(50) - 原始单位",
      "standardized_value": "NUMERIC(20, 2) - 标准化值 (HKD)",
      "standardized_currency": "VARCHAR(10) DEFAULT 'HKD'",
      "fiscal_period": "VARCHAR(20) DEFAULT 'FY' - FY, H1, Q1, Q2, Q3, Q4"
    },
    "constraints": {
      "unique_metric": "UNIQUE (company_id, year, fiscal_period, metric_name)"
    }
  },
  
  "fiscal_periods": {
    "standard_names": [
      {"code": "FY", "canonical_zh": "全年", "synonyms": ["Annual", "Year", "全年", "年度", "年度业绩", "Full Year"]},
      {"code": "H1", "canonical_zh": "上半年", "synonyms": ["Interim", "Half Year", "上半年", "中期", "中期业绩", "First Half"]},
      {"code": "H2", "canonical_zh": "下半年", "synonyms": ["Second Half", "下半年", "下半年业绩"]},
      {"code": "Q1", "canonical_zh": "第一季度", "synonyms": ["First Quarter", "第一季度", "一季报", "季报"]},
      {"code": "Q2", "canonical_zh": "第二季度", "synonyms": ["Second Quarter", "第二季度", "二季报"]},
      {"code": "Q3", "canonical_zh": "第三季度", "synonyms": ["Third Quarter", "第三季度", "三季报"]},
      {"code": "Q4", "canonical_zh": "第四季度", "synonyms": ["Fourth Quarter", "第四季度", "四季报"]}
    ],
    "default_period": "FY",
    "description": "财政期间标准代码，用于 financial_metrics.fiscal_period 字段"
  },
  
